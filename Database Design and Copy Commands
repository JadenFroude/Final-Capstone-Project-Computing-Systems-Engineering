CREATE Database recommendation_database;

CREATE TABLE ratings (
    tconst VARCHAR(20) PRIMARY KEY,
    averageRating NUMERIC(3,1),
    numVotes INTEGER
);

CREATE TABLE movies (
    tconst TEXT,
    titleType TEXT,
    primaryTitle TEXT,
    originalTitle TEXT,
    isAdult INTEGER,
    startYear TEXT,
    endYear TEXT,
    runtimeMinutes TEXT,
    genres TEXT
 );

CREATE TABLE principals (
    tconst VARCHAR(20),
    ordering INTEGER,
    nconst VARCHAR(20),
    category VARCHAR(100),
    job TEXT,
    characters TEXT
);

CREATE TABLE people (
    nconst VARCHAR(20) PRIMARY KEY,
    primaryName TEXT,
    birthYear INTEGER,
    deathYear INTEGER,
    primaryProfession TEXT,
    knownForTitles TEXT
);



